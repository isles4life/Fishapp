{
  "expo": {
    "name": "FishLeague",
    "slug": "fishleague",
    "scheme": "fishleague",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/app-icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1821"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.fishleague",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Take a photo of your catch and scan the mat QR code",
        "NSPhotoLibraryUsageDescription": "Choose a photo of your catch to submit to the tournament",
        "NSLocationWhenInUseUsageDescription": "Verify you are fishing at an approved location",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.fishleague",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#152515"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "apiBaseUrl": "https://api.fishleague.app",
      "eas": {
        "projectId": "692c9886-3f70-4b06-a9b7-78b9d3f65411"
      }
    },
    "plugins": [
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/app-icon.png",
          "color": "#152515",
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Take a photo of your catch and scan the mat QR code"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Verify you are fishing at an approved location"
        }
      ],
      "@stripe/stripe-react-native"
    ]
  }
}
