// FishLeague MVP – Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  EMAIL
  APPLE
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum ModerationActionType {
  APPROVE
  REJECT
  SUSPEND_USER
  FLAG
}

enum ScoringMethod {
  LENGTH
  WEIGHT
  FISH_COUNT
  SPECIES_COUNT
}

enum TournamentPostType {
  CATCH
  ANNOUNCEMENT
  CHECK_IN
  ANGLER_POST
}

enum UserRole {
  USER
  ADMIN
  TOURNAMENT_ADMIN
}

enum WaterType {
  FRESHWATER
  SALTWATER
  BOTH
}

enum WarningLevel {
  MINOR
  MAJOR
  FINAL
}

model User {
  id               String    @id @default(uuid())
  email            String?   @unique
  appleId          String?   @unique
  authProvider     AuthProvider
  displayName      String
  regionId         String?
  role             UserRole  @default(USER)
  passwordHash     String?
  suspended        Boolean   @default(false)
  pushToken        String?   @db.VarChar(500)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  region           Region?   @relation(fields: [regionId], references: [id])
  submissions      Submission[]
  leaderboardEntries LeaderboardEntry[]
  moderationActions  ModerationAction[] @relation("ModeratorActions")
  profile          AnglerProfile?
  props            CatchProp[]
  comments         CatchComment[]
  catchCommentProps CatchCommentProp[]
  postComments     TournamentPostComment[]
  postCommentProps TournamentPostCommentProp[]
  warnings         UserWarning[]
  issuedWarnings   UserWarning[] @relation("IssuedWarnings")
  checkIns         TournamentCheckIn[]
  tournamentAdminRequests TournamentAdminRequest[]
  reviewedRequests TournamentAdminRequest[] @relation("ReviewedRequests")
  directedTournaments Tournament[] @relation("TournamentDirector")
  tournamentPosts  TournamentPost[]
  tournamentEntries TournamentEntry[]

  @@index([regionId])
}

model Region {
  id          String   @id @default(uuid())
  name        String   @unique
  // Simple bounding box: minLat, maxLat, minLng, maxLng
  minLat      Float
  maxLat      Float
  minLng      Float
  maxLng      Float
  createdAt   DateTime @default(now())

  users        User[]
  tournaments  Tournament[]
}

model Tournament {
  id              String    @id @default(uuid())
  regionId        String
  name            String
  weekNumber      Int
  year            Int
  startsAt        DateTime
  endsAt          DateTime
  isOpen          Boolean   @default(false)
  entryFeeCents   Int       @default(0)
  prizePoolCents  Int       @default(0)
  prizeStructure  Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  checkInCode     String?   @unique
  scoringMethod   ScoringMethod @default(LENGTH)

  description     String?
  directorId      String?
  bannerKey       String?

  region      Region    @relation(fields: [regionId], references: [id])
  director    User?     @relation("TournamentDirector", fields: [directorId], references: [id], onDelete: SetNull)
  submissions Submission[]
  leaderboardEntries LeaderboardEntry[]
  checkIns    TournamentCheckIn[]
  tournamentAdminRequests TournamentAdminRequest[]
  posts       TournamentPost[]
  entries     TournamentEntry[]

  @@unique([regionId, weekNumber, year])
  @@index([regionId, isOpen])
}

model TournamentCheckIn {
  id           String     @id @default(uuid())
  userId       String
  tournamentId String
  checkedInAt  DateTime   @default(now())

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId])
  @@index([tournamentId])
}

model MatSerial {
  id          String    @id @default(uuid())
  serialCode  String    @unique
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  submissions Submission[]
}

model Submission {
  id               String           @id @default(uuid())
  userId           String
  tournamentId     String
  matSerialId      String?
  status           SubmissionStatus @default(PENDING)

  fishLengthCm     Float
  gpsLat           Float
  gpsLng           Float
  capturedAt       DateTime         // client timestamp
  serverReceivedAt DateTime         @default(now())

  photo1Key        String?          // S3 key – mat photo (optional, mat-free submissions omit this)
  photo2Key        String           // S3 key – fish photo with measuring device (mat, ruler, or tape)
  imageHash1       String?
  imageHash2       String

  speciesName      String?
  speciesCategory  String?

  flagDuplicateHash    Boolean @default(false)
  flagDuplicateGps     Boolean @default(false)
  flagSuspectPhoto     Boolean @default(false)
  flagSuspectLength    Boolean @default(false)
  flagSuspectSpecies   Boolean @default(false)
  estimatedLengthCm    Float?
  aiSuggestedSpecies   String?
  released             Boolean @default(false)
  fishWeightOz         Float?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User       @relation(fields: [userId], references: [id])
  tournament       Tournament @relation(fields: [tournamentId], references: [id])
  matSerial        MatSerial? @relation(fields: [matSerialId], references: [id])
  moderationActions ModerationAction[]
  leaderboardEntry  LeaderboardEntry?
  props            CatchProp[]
  comments         CatchComment[]
  tournamentPost   TournamentPost?

  @@index([tournamentId, status])
  @@index([userId, tournamentId])
  @@index([imageHash1])
  @@index([imageHash2])
  @@index([gpsLat, gpsLng])
}

model LeaderboardEntry {
  id           String   @id @default(uuid())
  tournamentId String
  userId       String
  fishLengthCm Float
  score        Float    @default(0)
  submissionId String   @unique
  rank         Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  submission   Submission @relation(fields: [submissionId], references: [id])

  @@unique([tournamentId, userId])
  @@index([tournamentId, fishLengthCm(sort: Desc)])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  actorId   String?
  actorName String?
  targetId  String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

model ModerationAction {
  id           String               @id @default(uuid())
  submissionId String
  moderatorId  String
  actionType   ModerationActionType
  note         String?
  createdAt    DateTime             @default(now())

  submission   Submission @relation(fields: [submissionId], references: [id])
  moderator    User       @relation("ModeratorActions", fields: [moderatorId], references: [id])

  @@index([submissionId])
}

model CatchProp {
  id           String     @id @default(uuid())
  submissionId String
  userId       String
  createdAt    DateTime   @default(now())
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([submissionId, userId])
  @@index([submissionId])
}

model CatchComment {
  id           String     @id @default(uuid())
  submissionId String
  userId       String
  body         String     @db.VarChar(500)
  createdAt    DateTime   @default(now())
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  props        CatchCommentProp[]
  @@index([submissionId, createdAt])
}

model CatchCommentProp {
  id        String       @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime     @default(now())
  comment   CatchComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([commentId, userId])
  @@index([commentId])
}

model UserWarning {
  id           String       @id @default(uuid())
  userId       String
  issuedById   String
  level        WarningLevel
  reason       String       @db.VarChar(1000)
  acknowledged Boolean      @default(false)
  createdAt    DateTime     @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  issuedBy     User         @relation("IssuedWarnings", fields: [issuedById], references: [id])
  @@index([userId, createdAt(sort: Desc)])
}

model TournamentAdminRequest {
  id           String    @id @default(uuid())
  userId       String
  tournamentId String
  status       String    @default("PENDING") // PENDING | APPROVED | REJECTED
  message      String?   @db.VarChar(500)
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  reviewedBy   User?      @relation("ReviewedRequests", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([userId, tournamentId])
  @@index([status])
}

// ─── Angler Profile ───────────────────────────────────────────────────────────

model AnglerProfile {
  id                 String     @id @default(uuid())
  userId             String     @unique
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  username           String     @unique
  bio                String?    @db.VarChar(250)
  profilePhotoUrl    String?
  verifiedAngler     Boolean    @default(false)
  birthday           DateTime?

  // Location
  homeState          String?
  homeCity           String?
  country            String?
  zipCode            String?

  // Fishing preferences
  primarySpecies     String[]
  favoriteTechniques String[]
  favoriteBaits      String[]
  preferredWaterType WaterType?

  // Gear
  favoriteRod        String?
  favoriteReel       String?
  favoriteLine       String?
  favoriteBoat       String?
  sponsorTags        String[]

  // Reputation (maintained by moderation system)
  sportsmanshipScore Float      @default(5.0)
  ruleViolations     Int        @default(0)

  // Social
  followersCount     Int        @default(0)
  followingCount     Int        @default(0)
  allowFollowers     Boolean    @default(true)
  publicProfile      Boolean    @default(true)

  // Badges & activity
  badges             String[]
  lastActiveAt       DateTime   @default(now())
  profileViews       Int        @default(0)

  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  achievements       Achievement[]
  followers          Follower[]  @relation("FollowerTarget")
  following          Follower[]  @relation("FollowerActor")

  @@index([username])
  @@index([publicProfile])
}

model Achievement {
  id        String        @id @default(uuid())
  profileId String
  profile   AnglerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  badge     String
  earnedAt  DateTime      @default(now())

  @@index([profileId])
}

model Follower {
  id        String        @id @default(uuid())
  actorId   String
  actor     AnglerProfile @relation("FollowerActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetId  String
  target    AnglerProfile @relation("FollowerTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([actorId, targetId])
  @@index([targetId])
}

model TournamentEntry {
  id                    String   @id @default(uuid())
  userId                String
  tournamentId          String
  stripePaymentIntentId String?
  feeCents              Int
  platformFeeCents      Int
  status                String   @default("PENDING") // PENDING | PAID | REFUNDED
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId])
  @@index([tournamentId])
  @@index([stripePaymentIntentId])
}

model TournamentPost {
  id           String              @id @default(uuid())
  tournamentId String
  userId       String
  type         TournamentPostType
  body         String?             @db.VarChar(1000)
  photoKey     String?             // S3 key for ANGLER_POST photos
  submissionId String?             @unique // only set on CATCH posts

  createdAt    DateTime            @default(now())

  tournament   Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id])
  submission   Submission?         @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  postComments TournamentPostComment[]

  @@index([tournamentId, createdAt(sort: Desc)])
}

model TournamentPostComment {
  id        String          @id @default(uuid())
  postId    String
  userId    String
  body      String          @db.VarChar(500)
  gifUrl    String?
  createdAt DateTime        @default(now())

  post      TournamentPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  props     TournamentPostCommentProp[]

  @@index([postId, createdAt])
}

model TournamentPostCommentProp {
  id        String                 @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime               @default(now())
  comment   TournamentPostComment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([commentId, userId])
  @@index([commentId])
}
